---
import { directus } from '../../../lib/directus';
import { readItems } from '@directus/sdk';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import '../../../styles/global.css';

export const prerender = true;

export async function getStaticPaths() {
  try {
    const categorias = await directus.request(readItems('Categorias', { fields: ['id', 'translations.*'] }));
    const items = await directus.request(readItems('Eventos', { fields: ['id', 'categoria_id', 'translations.*'] }));

    const paths: any[] = [];
    items.forEach((item: any) => {
      item.translations?.forEach((translation: any) => {
        const lang = translation.languages_code;
        const itemSlug = translation.slug;

        const category = categorias.find((c: any) => c.id === item.categoria_id);
        const categoryTranslation = category?.translations?.find((t: any) => t.languages_code === lang);
        const categorySlug = categoryTranslation?.slug;

        if (lang && categorySlug && itemSlug) {
          paths.push({
            params: { lang, category: categorySlug, slug: itemSlug },
            props: { id: item.id, itemTranslations: item.translations, categoryTranslations: category?.translations }
          });
        }
      });
    });

    return paths;
  } catch (error) {
    console.error('Failed to fetch data for dynamic slugs', error);
    return [
      { params: { lang: 'es', category: 'eventos', slug: 'fiestas-julianas' }, props: { id: 1, itemTranslations: [], categoryTranslations: [] } }
    ];
  }
}

const { lang, category, slug } = Astro.params;
const { id, itemTranslations, categoryTranslations } = Astro.props;

let itemData = null;
try {
  const itemResponse = await directus.request(readItems('Eventos', {
    filter: { id: { _eq: id } },
    fields: ['*', 'translations.*']
  }));
  const item = itemResponse[0];
  const translation = item?.translations?.find((t: any) => t.languages_code === lang) || {};
  itemData = { ...item, ...translation };
} catch (error) {
  console.error('Failed to fetch item details');
}
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{itemData?.title || slug}</title>
  </head>
  <body class="bg-canvas-100 text-ink-900 font-sans">
    <header class="p-6 flex justify-between items-center border-b border-ink-300">
      <a href={`/${lang}`} class="text-2xl font-bold font-serif text-ink-900 tracking-tightest">Guayaquil.</a>
      <LanguageSwitcher currentLang={lang} translations={itemTranslations} categoryTranslations={categoryTranslations} type="item" />
    </header>
    
    <main class="p-8 max-w-5xl mx-auto mt-12">
      <p class="text-sm uppercase tracking-extreme text-terra-500 font-bold mb-4">{category}</p>
      <h1 class="heading-section text-ink-900 mb-8">{itemData?.title || slug}</h1>
      
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-ink-300">
        <div class="prose lg:prose-xl text-ink-700" set:html={itemData?.description || '<p>Contenido no disponible.</p>'} />
      </div>
    </main>
  </body>
</html>
