---
import { 
  Thermometer, 
  DollarSign, 
  Globe, 
  Clock, 
  Plane, 
  Bus, 
  CableCar 
} from 'lucide-react';

interface Props {
  pageData: any;
  lang: string;
}

const { pageData, lang } = Astro.props;

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || 'http://localhost:8505';

// Localized Connection Stats for the banner
const connectionStats: Record<string, Array<{ value: string; label: string }>> = {
  es: [
    { value: "1h 45min", label: "Islas Galápagos" },
    { value: "2 horas", label: "Playas del Pacífico" },
    { value: "3 horas", label: "Andes ecuatorianos" },
    { value: "5 horas", label: "Selva Amazónica" }
  ],
  en: [
    { value: "1h 45min", label: "Galapagos Islands" },
    { value: "2 hours", label: "Pacific Beaches" },
    { value: "3 hours", label: "Ecuadorian Andes" },
    { value: "5 hours", label: "Amazon Rainforest" }
  ],
  pt: [
    { value: "1h 45min", label: "Ilhas Galápagos" },
    { value: "2 horas", label: "Praias do Pacífico" },
    { value: "3 horas", label: "Andes equatorianos" },
    { value: "5 horas", label: "Floresta Amazônica" }
  ],
  fr: [
    { value: "1h 45min", label: "Îles Galapagos" },
    { value: "2 heures", label: "Plages du Pacifique" },
    { value: "3 heures", label: "Andes équatoriennes" },
    { value: "5 heures", label: "Forêt Amazonienne" }
  ],
  de: [
    { value: "1h 45min", label: "Galapagos-Inseln" },
    { value: "2 Stunden", label: "Pazifikstrände" },
    { value: "3 Stunden", label: "Ecuadorianische Anden" },
    { value: "5 Stunden", label: "Amazonas-Regenwald" }
  ]
};

const localizedStats = connectionStats[lang] || connectionStats['es'];

// Quick Info Icon Mapper
const quickInfoIcons = [
  Thermometer,
  DollarSign,
  Globe,
  Clock
];

// Transport Cards Configuration
const transportConfigs = [
  { icon: Plane, bg: 'bg-[#fbf2e5]', border: 'border-amber-200/50', iconColor: 'text-terra-600' },
  { icon: Bus, bg: 'bg-[#eef6f3]', border: 'border-estuary-200/40', iconColor: 'text-estuary-600' },
  { icon: CableCar, bg: 'bg-[#f8f0eb]', border: 'border-terra-200/30', iconColor: 'text-terra-500' }
];

const bannerImageUrl = pageData?.trip_connections_banner_image 
  ? `${directusUrl}/assets/${pageData.trip_connections_banner_image}` 
  : '';
---

<section class="relative w-full py-24 sm:py-32 lg:py-40 bg-canvas-100 text-ink-900 overflow-hidden select-none">
  <div class="w-full max-w-6xl mx-auto px-6 md:px-12 flex flex-col">
    
    <!-- Section Header -->
    <div class="flex flex-col mb-16 sm:mb-20">
      {pageData?.trip_section_label && (
        <div class="flex items-center gap-3 mb-4">
          <span class="h-[1px] w-6 bg-amber-500/80"></span>
          <span class="text-[10px] sm:text-xs font-sans font-semibold tracking-[0.2em] text-amber-600 uppercase">
            {pageData.trip_section_label}
          </span>
        </div>
      )}
      <h2 class="font-serif font-bold text-ink-900 leading-[1.05] tracking-tight uppercase flex flex-col">
        <span class="text-4xl sm:text-5xl lg:text-6xl text-ink-900">
          {pageData?.trip_heading_line1}
        </span>
        <span class="text-4xl sm:text-5xl lg:text-6xl text-outline mt-1">
          {pageData?.trip_heading_line2_stroke}
        </span>
      </h2>
    </div>

    <!-- Quick Info Cards Grid -->
    {pageData?.trip_quick_info && Array.isArray(pageData.trip_quick_info) && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16 sm:mb-24">
        {pageData.trip_quick_info.map((info: any, index: number) => {
          const Icon = quickInfoIcons[index % quickInfoIcons.length] || Thermometer;
          return (
            <div class="flex flex-col bg-white rounded-3xl p-6 sm:p-8 shadow-sm border border-canvas-200/40">
              <Icon className="w-5 h-5 text-amber-500 mb-4" />
              <span class="text-xl sm:text-2xl font-serif font-bold text-ink-900 mb-1">
                {info.value}
              </span>
              <span class="text-[9px] sm:text-[10px] font-sans font-semibold tracking-wider text-ink-500 uppercase">
                {info.label}
              </span>
            </div>
          );
        })}
      </div>
    )}

    <!-- Transport Cards Grid -->
    {pageData?.trip_transport && Array.isArray(pageData.trip_transport) && (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-16 sm:mb-24">
        {pageData.trip_transport.map((item: any, index: number) => {
          const config = transportConfigs[index % transportConfigs.length] || { icon: Plane, bg: 'bg-canvas-200/50', border: 'border-canvas-300/40', iconColor: 'text-amber-500' };
          const Icon = config.icon;
          return (
            <div class={`flex flex-col ${config.bg} border ${config.border} rounded-3xl p-8 sm:p-10 hover:shadow-md transition-shadow duration-300`}>
              
              <!-- Icon Container -->
              <div class="w-10 h-10 flex items-center justify-center bg-white rounded-lg shadow-sm mb-5">
                <Icon className={`w-4 h-4 ${config.iconColor}`} />
              </div>
              
              <!-- Title -->
              <h3 class="text-lg sm:text-xl font-serif font-bold text-ink-900 mb-3 leading-snug">
                {item.title}
              </h3>
              
              <!-- Stats/Type -->
              <p class="text-sm font-sans font-bold text-ink-800 mb-2 leading-relaxed">
                {item.stats}
              </p>
              
              <!-- Details -->
              <p class="text-xs font-sans text-ink-600 leading-relaxed">
                {item.details}
              </p>
              
            </div>
          );
        })}
      </div>
    )}

    <!-- Connections Banner -->
    {bannerImageUrl && (
      <div class="relative w-full aspect-[16/10] sm:aspect-[2.1] lg:aspect-[2.4] rounded-[2rem] overflow-hidden bg-canvas-900 shadow-md">
        
        <!-- Background Image -->
        <img 
          src={bannerImageUrl} 
          alt={pageData?.trip_connections_banner_subtitle || "Guayaquil Conectividad"} 
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
        
        <!-- Dark Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/35 to-black/20 z-10"></div>
        
        <!-- Banner Content -->
        <div class="absolute inset-0 p-8 sm:p-12 lg:p-16 z-20 flex flex-col justify-between h-full">
          
          <!-- Top: Label & Title -->
          <div class="flex flex-col">
            {pageData?.trip_connections_banner_title && (
              <div class="flex items-center gap-3 mb-3">
                <span class="h-[1px] w-6 bg-amber-400"></span>
                <span class="text-[10px] sm:text-xs font-sans font-semibold tracking-[0.2em] text-amber-400 uppercase">
                  {pageData.trip_connections_banner_title}
                </span>
              </div>
            )}
            {pageData?.trip_connections_banner_subtitle && (
              <h3 class="text-2xl sm:text-3xl lg:text-4xl xl:text-5xl font-serif font-bold text-white max-w-2xl leading-tight tracking-tight uppercase">
                {pageData.trip_connections_banner_subtitle}
              </h3>
            )}
          </div>
          
          <!-- Bottom: Translucent Glass Stats -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 w-full mt-6 sm:mt-0">
            {localizedStats.map((stat) => (
              <div class="flex flex-col bg-white/10 backdrop-blur-md border border-white/10 rounded-2xl p-4 sm:p-5 select-none hover:bg-white/15 transition-colors">
                <span class="text-base sm:text-lg font-serif font-bold text-amber-400 mb-1 leading-none">
                  {stat.value}
                </span>
                <span class="text-[9px] sm:text-[10px] font-sans font-semibold tracking-wider text-white/80 uppercase">
                  {stat.label}
                </span>
              </div>
            ))}
          </div>
          
        </div>

      </div>
    )}

  </div>
</section>
