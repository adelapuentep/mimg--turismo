---
interface Props {
  pageData: any;
  eventos: any[];
  lang: string;
}

const { pageData, eventos, lang } = Astro.props;

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL || 'http://localhost:8505';

// Category color mapper
const getCategoryColor = (label: string) => {
  const norm = label ? label.toLowerCase().trim() : '';
  if (norm.includes('cultura')) return 'bg-amber-600 text-white';
  if (norm.includes('deporte')) return 'bg-estuary-600 text-white';
  if (norm.includes('música') || norm.includes('music')) return 'bg-terra-500 text-white';
  if (norm.includes('gastronom') || norm.includes('gastronomy')) return 'bg-amber-800 text-white';
  return 'bg-canvas-400 text-ink-900';
};
---

<section class="relative w-full py-24 sm:py-32 lg:py-40 bg-terra-700 text-white overflow-hidden select-none">
  <div class="w-full max-w-6xl mx-auto px-6 md:px-12 flex flex-col">
    
    <!-- Section Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 mb-16 sm:mb-20">
      
      <!-- Left: Label & Title -->
      <div class="flex flex-col">
        {pageData?.events_section_label && (
          <div class="flex items-center gap-3 mb-4">
            <span class="h-[1px] w-6 bg-amber-400/80"></span>
            <span class="text-[10px] sm:text-xs font-sans font-semibold tracking-[0.2em] text-amber-300 uppercase">
              {pageData.events_section_label}
            </span>
          </div>
        )}
        <h2 class="font-serif font-bold leading-[1.05] tracking-tight uppercase flex flex-col">
          <span class="text-4xl sm:text-5xl lg:text-6xl text-white">
            {pageData?.events_heading_line1 || 'Eventos'}
          </span>
          <span class="text-4xl sm:text-5xl lg:text-6xl text-outline-white mt-1">
            {pageData?.events_heading_line2_stroke || '& Cultura'}
          </span>
        </h2>
      </div>

      <!-- Right: Link -->
      <a 
        href={`/${lang}/eventos`} 
        class="group text-[10px] sm:text-xs font-sans font-semibold tracking-[0.2em] text-canvas-200 hover:text-white uppercase flex items-center gap-2 pb-1 border-b border-canvas-200/30 hover:border-white transition-colors duration-300 whitespace-nowrap"
      >
        <span>Agenda Completa</span>
        <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
      </a>
      
    </div>

    <!-- Event Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 xl:gap-8">
      {eventos && eventos.map((evento) => {
        // Resolve translated content
        const translation = evento.translations?.find((t: any) => t.languages_code === lang) || {};
        const title = translation.title || '';
        const month = translation.month || '';
        
        // Resolve category
        const categoryTranslation = evento.categoria_id?.translations?.find((t: any) => t.languages_code === lang) || {};
        const categoryLabel = categoryTranslation.label || '';
        
        // Resolve image URL
        const imageUrl = evento.imagen ? `${directusUrl}/assets/${evento.imagen}` : '';
        const categoryColorClass = getCategoryColor(categoryLabel);

        return (
          <div class="group relative aspect-[3/4] w-full rounded-3xl overflow-hidden bg-canvas-800 shadow-lg cursor-pointer">
            
            <!-- Event Image with Hover Zoom -->
            {imageUrl && (
              <img 
                src={imageUrl} 
                alt={title} 
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-105"
              />
            )}
            
            <!-- Dark Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/35 to-transparent z-10"></div>
            
            <!-- Card Content (Bottom Aligned) -->
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8 z-20 flex flex-col items-start justify-end">
              
              <!-- Category Pill -->
              {categoryLabel && (
                <span class={`px-3 py-1 rounded-full text-[9px] tracking-wider font-sans font-bold uppercase mb-3 shadow-sm ${categoryColorClass}`}>
                  {categoryLabel}
                </span>
              )}
              
              <!-- Event Title -->
              <h3 class="text-xl sm:text-2xl font-serif font-bold text-white mb-2 leading-tight tracking-tight select-none">
                {title}
              </h3>
              
              <!-- Event Date -->
              {month && (
                <span class="text-[10px] sm:text-xs font-sans tracking-widest text-white/60 uppercase">
                  {month}
                </span>
              )}
              
            </div>

          </div>
        );
      })}
    </div>

  </div>
</section>
