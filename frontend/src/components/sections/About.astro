---
interface Props {
  pageData: any;
}

const { pageData } = Astro.props;

const marquee1 = pageData?.kinetic_marquee_line1 
  ? pageData.kinetic_marquee_line1.toUpperCase() 
  : "";
const marquee2 = pageData?.kinetic_marquee_line2 
  ? pageData.kinetic_marquee_line2.toUpperCase() 
  : "";
---

<section class="about-section relative w-full py-32 sm:py-48 lg:py-64 bg-canvas-100 overflow-hidden flex flex-col justify-center select-none">
  
  <!-- Top Kinetic Marquee -->
  {marquee1 && (
    <div class="absolute top-12 left-0 w-full overflow-hidden pointer-events-none select-none z-0 whitespace-nowrap opacity-40">
      <div class="marquee-1 text-[12vw] font-serif font-bold text-canvas-200/60 uppercase tracking-tighter leading-none">
        {marquee1}
      </div>
    </div>
  )}

  <!-- Main Grid Content -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start my-8">
    
    <!-- Left Column: Section Label & Heading -->
    <div class="lg:col-span-5 flex flex-col items-start">
      {pageData?.kinetic_section_label && (
        <span class="text-[10px] sm:text-xs font-sans font-semibold tracking-widest text-terra-600 uppercase mb-4">
          {pageData.kinetic_section_label}
        </span>
      )}
      <h2 class="font-serif font-bold text-ink-900 leading-[1.05] tracking-tight uppercase flex flex-col">
        <span class="text-4xl sm:text-5xl lg:text-6xl text-ink-900">
          {pageData?.kinetic_heading_line1}
        </span>
        <span class="text-4xl sm:text-5xl lg:text-6xl text-outline mt-1">
          {pageData?.kinetic_heading_line2_stroke}
        </span>
      </h2>
    </div>

    <!-- Right Column: Paragraph, Divider, & Stats -->
    <div class="lg:col-span-7 flex flex-col">
      {pageData?.kinetic_body_paragraph && (
        <p class="text-sm sm:text-base text-ink-700 font-sans leading-relaxed max-w-2xl mb-8">
          {pageData.kinetic_body_paragraph}
        </p>
      )}

      <!-- Divider Line -->
      <div class="w-full h-[1px] bg-canvas-300/60 mb-8"></div>

      <!-- Stats Grid -->
      {pageData?.kinetic_stats && Array.isArray(pageData.kinetic_stats) && (
        <div class="grid grid-cols-3 gap-6 sm:gap-8">
          {pageData.kinetic_stats.map((stat: any) => (
            <div class="flex flex-col">
              <span class="text-2xl sm:text-3xl font-serif font-bold text-terra-600 leading-none mb-2">
                {stat.value}
              </span>
              <span class="text-[9px] sm:text-[10px] font-sans font-semibold tracking-wider text-ink-500 uppercase">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Bottom Kinetic Marquee -->
  {marquee2 && (
    <div class="absolute bottom-12 left-0 w-full overflow-hidden pointer-events-none select-none z-0 whitespace-nowrap opacity-40">
      <div class="marquee-2 text-[12vw] font-serif font-bold text-canvas-200/60 uppercase tracking-tighter leading-none">
        {marquee2}
      </div>
    </div>
  )}
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('.about-section');
  const marquee1 = document.querySelector('.marquee-1');
  const marquee2 = document.querySelector('.marquee-2');

  if (section) {
    if (marquee1) {
      gsap.fromTo(marquee1,
        { x: '40vw' },
        {
          x: '-40vw',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2
          }
        }
      );
    }

    if (marquee2) {
      gsap.fromTo(marquee2,
        { x: '-40vw' },
        {
          x: '40vw',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2
          }
        }
      );
    }
  }
</script>
