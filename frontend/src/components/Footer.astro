const currentNav = localizedNav[lang] || localizedNav['es'];

// Resolve translated settings
const translation = settings?.translations?.find((t: any) => t.languages_code === lang) || {};
const headline = translation.footer_headline || 'Tu próxima aventura empieza aquí.';
const copyright = translation.footer_copyright || 'GAD Municipal de Guayaquil';

// Parse headline to split last word for distinct style
const words = headline.trim().split(' ');
const lastWord = words.pop() || '';
const mainHeadlineText = words.join(' ');
---

<footer class="w-full bg-canvas-100 text-ink-900 border-t border-canvas-200/50 pt-24 pb-12 overflow-hidden select-none">
  <div class="w-full max-w-6xl mx-auto px-6 md:px-12 flex flex-col">
    
    <!-- Top Part: Big Heading & CTA -->
    <div class="flex flex-col items-start mb-16 sm:mb-24">
      <h2 class="font-serif font-bold text-4xl sm:text-5xl lg:text-6xl tracking-tight leading-[1.1] text-ink-900 max-w-2xl mb-8">
        <span>{mainHeadlineText} </span><span class="text-terra-500">{lastWord}</span>
      </h2>
      
      <a 
        href={`/${lang}#descubre-gye`}
        class="group px-8 py-3.5 rounded-full bg-ink-900 text-white font-sans font-bold text-xs tracking-widest uppercase flex items-center justify-center gap-2 hover:bg-ink-800 transition-all duration-300 shadow-md hover:shadow-lg active:scale-95"
      >
        <span>{currentNav.cta}</span>
        <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
      </a>
    </div>

    <!-- Divider Line -->
    <div class="w-full h-[1px] bg-canvas-200 mb-16"></div>

    <!-- Middle Part: Links Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 sm:gap-12 mb-20">
      {currentNav.columns.map((column) => (
        <div class="flex flex-col items-start">
          <span class="text-[10px] sm:text-xs font-sans font-bold tracking-[0.2em] text-ink-400 uppercase mb-5 select-none">
            {column.title}
          </span>
          <ul class="flex flex-col gap-3">
            {column.links.map((link) => (
              <li>
                <a 
                  href={link.href}
                  class="text-xs sm:text-sm font-sans font-medium text-ink-600 hover:text-ink-900 transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider Line -->
    <div class="w-full h-[1px] bg-canvas-200 mb-8"></div>

    <!-- Bottom Part: Logo & Copyright -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 text-ink-500">
      
      <!-- Brand Logo -->
      <div class="flex items-center">
        <span class="font-serif font-bold text-ink-900 mr-2 text-base sm:text-lg select-none">
          {settings?.logo_text || 'GYE'}
        </span>
        <span class="text-[9px] tracking-widest text-ink-500 uppercase font-sans font-bold select-none pb-0.5 border-l border-canvas-300 pl-2">
          {settings?.logo_subtitle || 'Dirección General de Turismo'}
        </span>
      </div>

      <!-- Copyright text -->
      <span class="text-[10px] sm:text-xs font-sans font-medium tracking-wide">
        &copy; {new Date().getFullYear()} {copyright}
      </span>

    </div>

  </div>
</footer>
